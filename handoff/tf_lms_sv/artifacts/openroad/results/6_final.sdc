set_input_transition 0.1000 [get_ports {dxin[2]}]
set_input_transition 0.1000 [get_ports {dxin[1]}]
set_input_transition 0.1000 [get_ports {dxin[0]}]
set_input_transition 0.1000 [get_ports {xin[7]}]
set_input_transition 0.1000 [get_ports {xin[6]}]
set_input_transition 0.1000 [get_ports {xin[5]}]
set_input_transition 0.1000 [get_ports {xin[4]}]
set_input_transition 0.1000 [get_ports {xin[3]}]
